# Test target binaries — built locally, referenced by config.yaml,
# not committed. Keep the README and .gitkeep visible so the directory
# structure survives a fresh clone.
targets/*
!targets/README.md
!targets/.gitkeep

# Pipeline outputs — always regeneratable from inputs
build/
out/
warehouse/
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite-journal
*.db
*.parquet
*.arrow

# Ghidra project files
*.gpr
*.rep/
ghidra_projects/

# Renode artifacts
*.resd
*.trace
renode_logs/

# ML artifacts — too big, always retrainable
models/
checkpoints/
*.pt
*.pth
*.safetensors
*.mlpackage
*.mlmodel
*.onnx

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/
.python-version

# Snakemake
.snakemake/

# Environment and secrets
.env
.env.local
.env.*.local

# Notebooks
.ipynb_checkpoints/

# Editors and OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/
