#!/usr/bin/env -S uv run python
"""Run a SQL query against the ripcord parquet warehouse.

Discovers every parquet file under build/<target>/tables/<name>.parquet,
groups them by table name, and registers one DuckDB view per table that
unions all matching files (one row per (target, row) across targets).

Usage
-----
    scripts/query 'SELECT * FROM functions LIMIT 5'
    scripts/query < query.sql
    scripts/query                 # list registered tables and exit
    scripts/query --repl          # drop into an interactive duckdb REPL
                                    with the views pre-loaded

The views are named after the parquet file basenames, so adding a new
table is just "write a new parquet under build/<target>/tables/" — no
changes to this script required.
"""

from __future__ import annotations

import argparse
import glob
import os
import sys
import tempfile
from collections import defaultdict
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent


def discover_tables() -> dict[str, list[str]]:
    groups: dict[str, list[str]] = defaultdict(list)
    pattern = str(REPO_ROOT / "build" / "*" / "tables" / "*.parquet")
    for path in glob.glob(pattern):
        name = os.path.splitext(os.path.basename(path))[0]
        groups[name].append(path)
    return {k: sorted(v) for k, v in sorted(groups.items())}


def view_ddl(tables: dict[str, list[str]]) -> list[str]:
    stmts: list[str] = []
    for name, paths in tables.items():
        paths_sql = ", ".join(f"'{p}'" for p in paths)
        stmts.append(
            f"CREATE OR REPLACE VIEW {name} AS "
            f"SELECT * FROM read_parquet([{paths_sql}], union_by_name=true);"
        )
    return stmts


def print_table_summary(tables: dict[str, list[str]]) -> None:
    if not tables:
        print(
            "no parquet tables found under build/*/tables/ — "
            "run `snakemake --cores 4` to populate the warehouse",
            file=sys.stderr,
        )
        return
    print("registered views:", file=sys.stderr)
    for name, paths in tables.items():
        targets = sorted({Path(p).parent.parent.name for p in paths})
        print(
            f"  {name:24s}  {len(paths)} file(s) across targets: "
            f"{', '.join(targets)}",
            file=sys.stderr,
        )


def split_statements(sql: str) -> list[str]:
    """Split a SQL string on top-level semicolons.

    Handles `--` line comments and single/double-quoted string literals
    so apostrophes inside comments (e.g. "nm's output") don't confuse
    the splitter. Not a full SQL parser — does not handle /* */ block
    comments or dollar-quoted strings, neither of which appear in the
    query files we commit.
    """
    statements: list[str] = []
    buf: list[str] = []
    in_single = False
    in_double = False
    in_line_comment = False
    i = 0
    n = len(sql)
    while i < n:
        ch = sql[i]
        if in_line_comment:
            buf.append(ch)
            if ch == "\n":
                in_line_comment = False
            i += 1
            continue
        if (
            not in_single
            and not in_double
            and ch == "-"
            and i + 1 < n
            and sql[i + 1] == "-"
        ):
            in_line_comment = True
            buf.append(ch)
            i += 1
            continue
        if ch == "'" and not in_double:
            in_single = not in_single
        elif ch == '"' and not in_single:
            in_double = not in_double
        elif ch == ";" and not in_single and not in_double:
            stmt = "".join(buf).strip()
            if stmt:
                statements.append(stmt)
            buf = []
            i += 1
            continue
        buf.append(ch)
        i += 1
    tail = "".join(buf).strip()
    if tail:
        statements.append(tail)
    return statements


def run_query(tables: dict[str, list[str]], query: str) -> int:
    import duckdb  # lazy import so --repl path doesn't require it

    conn = duckdb.connect(":memory:")
    for stmt in view_ddl(tables):
        conn.execute(stmt)

    statements = split_statements(query)
    if not statements:
        return 0

    rc = 0
    for idx, stmt in enumerate(statements):
        try:
            result = conn.sql(stmt)
        except duckdb.Error as exc:
            print(f"query error in statement {idx + 1}: {exc}", file=sys.stderr)
            rc = 1
            continue
        if result is not None:
            if len(statements) > 1:
                # Label each result set when there's more than one, so
                # multi-statement query files produce legible output.
                first_line = stmt.splitlines()[0][:70]
                print(f"-- [{idx + 1}] {first_line}", file=sys.stderr)
            print(result)
    return rc


def exec_repl(tables: dict[str, list[str]]) -> int:
    stmts = view_ddl(tables)
    with tempfile.NamedTemporaryFile(
        "w", suffix=".sql", delete=False, prefix="ripcord_init_"
    ) as f:
        f.write("\n".join(stmts))
        init_path = f.name
    os.execvp("duckdb", ["duckdb", "-init", init_path])
    return 0  # unreachable


def main() -> int:
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--repl",
        action="store_true",
        help="drop into an interactive duckdb REPL with views pre-loaded",
    )
    parser.add_argument(
        "query",
        nargs="*",
        help="SQL query (joined with spaces). "
        "If omitted and stdin is a pipe, the query is read from stdin.",
    )
    args = parser.parse_args()

    tables = discover_tables()

    if args.repl:
        return exec_repl(tables)

    if args.query:
        return run_query(tables, " ".join(args.query))

    if not sys.stdin.isatty():
        query = sys.stdin.read().strip()
        if query:
            return run_query(tables, query)

    print_table_summary(tables)
    return 0


if __name__ == "__main__":
    sys.exit(main())
